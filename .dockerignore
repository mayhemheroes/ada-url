# .dockerignore for the commit-image build.
# Goal: bake in the FULL repo (including .git history — the grader uses it),
# dropping only local build artifacts and editor/OS cruft. Dev image, not minimal.

# ── Build outputs / local cruft ──────────────────────────────────────────────
# build.sh produces its outputs under /mayhem (=$OUT) and into build/ + build-tests/
# at build time; keep any local copies out of the context.
build/
build-*/
out/
.cpm-cache/
.cache/
*.o
*.a
*.so
*.dylib
**/__pycache__/

# ── Editor / OS noise ────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
.vscode/
.idea/
